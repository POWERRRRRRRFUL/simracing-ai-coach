<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>simcoach — {{ report.track_id }} / {{ report.car_id }}</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
  <style>
    :root {
      --bg: #0f1117;
      --surface: #1a1d27;
      --surface2: #22263a;
      --accent: #e63946;
      --accent2: #457b9d;
      --text: #e8eaf0;
      --muted: #7a7f9a;
      --border: #2e3250;
      --best: #4ade80;
      --ref: #60a5fa;
      --radius: 8px;
      --font: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      font-size: 15px;
      line-height: 1.6;
      padding: 0 0 60px;
    }

    /* ── Header ─────────────────────────────────────────────────────────── */
    .header {
      background: linear-gradient(135deg, #1a1d27 0%, #0f1117 100%);
      border-bottom: 2px solid var(--accent);
      padding: 28px 40px 20px;
    }
    .header h1 {
      font-size: 1.6rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      color: var(--text);
    }
    .header h1 span { color: var(--accent); }
    .header .meta {
      margin-top: 8px;
      color: var(--muted);
      font-size: 0.88rem;
      display: flex;
      gap: 24px;
      flex-wrap: wrap;
    }
    .header .meta strong { color: var(--text); }

    /* ── Layout ─────────────────────────────────────────────────────────── */
    .container { max-width: 1100px; margin: 0 auto; padding: 0 40px; }

    .section {
      margin-top: 36px;
    }
    .section-title {
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
      padding-bottom: 8px;
      margin-bottom: 16px;
    }

    /* ── Cards ───────────────────────────────────────────────────────────── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px 24px;
    }

    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
    @media (max-width: 700px) {
      .grid-2, .grid-3 { grid-template-columns: 1fr; }
    }

    /* ── Lap time display ───────────────────────────────────────────────── */
    .laptime-block {
      display: flex;
      align-items: center;
      gap: 32px;
      padding: 16px 24px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
    }
    .laptime-item { text-align: center; }
    .laptime-item .label { font-size: 0.78rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; }
    .laptime-item .value { font-size: 2rem; font-weight: 700; font-variant-numeric: tabular-nums; }
    .laptime-item.best   .value { color: var(--best); }
    .laptime-item.ref    .value { color: var(--ref); }
    .laptime-item.delta  .value { color: #f59e0b; }
    .divider { width: 1px; height: 60px; background: var(--border); }

    /* ── Stats table ────────────────────────────────────────────────────── */
    .stats-table { width: 100%; border-collapse: collapse; }
    .stats-table th {
      text-align: left;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--muted);
      padding: 6px 12px;
      border-bottom: 1px solid var(--border);
    }
    .stats-table td { padding: 8px 12px; border-bottom: 1px solid var(--border); }
    .stats-table tr:last-child td { border-bottom: none; }
    .stats-table .val-best { color: var(--best); font-weight: 600; }
    .stats-table .val-ref  { color: var(--ref);  font-weight: 600; }

    /* ── Lap history table ──────────────────────────────────────────────── */
    .lap-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    .lap-table th {
      background: var(--surface2);
      text-align: left;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      color: var(--muted);
      padding: 8px 14px;
    }
    .lap-table td { padding: 8px 14px; border-bottom: 1px solid var(--border); }
    .lap-table tr.is-best td { background: rgba(74,222,128,0.06); color: var(--best); }
    .lap-table .badge {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 1px 6px;
      border-radius: 4px;
      background: var(--accent);
      color: #fff;
      margin-left: 6px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    /* ── Charts ─────────────────────────────────────────────────────────── */
    .chart-container {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
    }
    .chart-wrapper { position: relative; height: 160px; }
    .chart-label {
      font-size: 0.78rem;
      font-weight: 600;
      text-transform: uppercase;
      color: var(--muted);
      letter-spacing: 0.06em;
      margin-bottom: 8px;
    }
    .charts-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    @media (max-width: 800px) { .charts-grid { grid-template-columns: 1fr; } }

    /* ── AI text sections ───────────────────────────────────────────────── */
    .ai-text {
      line-height: 1.75;
      color: var(--text);
    }
    .ai-text p { margin-bottom: 12px; }
    .ai-text ul, .ai-text ol { padding-left: 20px; margin-bottom: 12px; }
    .ai-text li { margin-bottom: 6px; }
    .ai-text strong { color: var(--best); }

    /* ── Focus items ────────────────────────────────────────────────────── */
    .focus-item {
      background: var(--surface2);
      border-left: 3px solid var(--accent);
      border-radius: 0 var(--radius) var(--radius) 0;
      padding: 14px 18px;
      margin-bottom: 12px;
    }
    .focus-item:last-child { margin-bottom: 0; }

    /* ── Footer ─────────────────────────────────────────────────────────── */
    .footer {
      margin-top: 48px;
      padding: 16px 40px;
      border-top: 1px solid var(--border);
      color: var(--muted);
      font-size: 0.82rem;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px;
    }

    /* ── Legend ─────────────────────────────────────────────────────────── */
    .legend {
      display: flex;
      gap: 20px;
      margin-bottom: 12px;
      font-size: 0.82rem;
    }
    .legend-dot {
      width: 12px; height: 12px;
      border-radius: 50%;
      display: inline-block;
      margin-right: 5px;
      vertical-align: middle;
    }
  </style>
</head>
<body>

<!-- ── Header ─────────────────────────────────────────────────────────────── -->
<div class="header">
  <div class="container">
    <h1><span>simcoach</span> — Post-Session Analysis</h1>
    <div class="meta">
      <span>Track: <strong>{{ report.track_id }}</strong></span>
      <span>Car: <strong>{{ report.car_id }}</strong></span>
      <span>Session: <strong>{{ report.session_id }}</strong></span>
      <span>Date: <strong>{{ report.session_date[:10] }}</strong></span>
      <span>Model: <strong>{{ report.llm_model }}</strong></span>
    </div>
  </div>
</div>

<div class="container">

<!-- ── Session Overview ────────────────────────────────────────────────────── -->
<div class="section">
  <div class="section-title">Session Overview</div>
  <div class="laptime-block">
    <div class="laptime-item best">
      <div class="label">Best Lap</div>
      <div class="value">{{ report.best_lap_time_str }}</div>
    </div>
    {% if report.reference_lap_time_str %}
    <div class="divider"></div>
    <div class="laptime-item ref">
      <div class="label">Reference (PB)</div>
      <div class="value">{{ report.reference_lap_time_str }}</div>
    </div>
    <div class="divider"></div>
    <div class="laptime-item delta">
      <div class="label">Delta</div>
      <div class="value">{{ report.delta_vs_reference_str }}</div>
    </div>
    {% endif %}
  </div>
</div>

<!-- ── Lap History ─────────────────────────────────────────────────────────── -->
{% if lap_summaries %}
<div class="section">
  <div class="section-title">Lap History</div>
  <div class="card" style="padding: 0; overflow: hidden;">
    <table class="lap-table">
      <thead>
        <tr>
          <th>Lap</th>
          <th>Time</th>
          <th>Max Speed</th>
          <th>Avg Speed</th>
          <th>Gear Changes</th>
          <th>ABS Events</th>
          <th>TC Events</th>
        </tr>
      </thead>
      <tbody>
        {% for lap in lap_summaries %}
        <tr class="{{ 'is-best' if lap.is_best else '' }}">
          <td>
            {{ lap.lap_id + 1 }}
            {% if lap.is_best %}<span class="badge">Best</span>{% endif %}
          </td>
          <td>{{ lap.lap_time_str }}</td>
          <td>{{ '%.0f km/h' % lap.max_speed_kmh if lap.max_speed_kmh else '—' }}</td>
          <td>{{ '%.0f km/h' % lap.avg_speed_kmh if lap.avg_speed_kmh else '—' }}</td>
          <td>{{ lap.gear_changes if lap.gear_changes is not none else '—' }}</td>
          <td>{{ lap.abs_events if lap.abs_events is not none else '—' }}</td>
          <td>{{ lap.tc_events if lap.tc_events is not none else '—' }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endif %}

<!-- ── Telemetry Charts ────────────────────────────────────────────────────── -->
<div class="section">
  <div class="section-title">Telemetry Traces — Best Lap vs Reference</div>
  <div class="chart-container">
    <div class="legend">
      <span><span class="legend-dot" style="background:#4ade80"></span>Best Lap</span>
      <span><span class="legend-dot" style="background:#60a5fa"></span>Reference</span>
    </div>
    <div class="charts-grid">
      <div>
        <div class="chart-label">Speed (km/h)</div>
        <div class="chart-wrapper"><canvas id="chartSpeed"></canvas></div>
      </div>
      <div>
        <div class="chart-label">Throttle</div>
        <div class="chart-wrapper"><canvas id="chartThrottle"></canvas></div>
      </div>
      <div>
        <div class="chart-label">Brake</div>
        <div class="chart-wrapper"><canvas id="chartBrake"></canvas></div>
      </div>
      <div>
        <div class="chart-label">Steering</div>
        <div class="chart-wrapper"><canvas id="chartSteering"></canvas></div>
      </div>
    </div>
  </div>
</div>

<!-- ── Best vs Reference Analysis ─────────────────────────────────────────── -->
<div class="section">
  <div class="section-title">Best Lap vs Reference</div>
  <div class="card ai-text">
    {{ report.best_vs_reference_analysis | replace('\n', '<br>') | safe }}
  </div>
</div>

<!-- ── Session Findings ────────────────────────────────────────────────────── -->
<div class="section">
  <div class="section-title">Session Findings</div>
  <div class="card ai-text">
    {{ report.session_findings | replace('\n', '<br>') | safe }}
  </div>
</div>

<!-- ── Coaching Summary ────────────────────────────────────────────────────── -->
<div class="section">
  <div class="section-title">Coaching Summary</div>
  <div class="card ai-text">
    {{ report.coaching_summary | replace('\n', '<br>') | safe }}
  </div>
</div>

<!-- ── Next Training Focus ─────────────────────────────────────────────────── -->
{% if report.next_training_focus %}
<div class="section">
  <div class="section-title">Next Training Focus</div>
  {% set lines = report.next_training_focus.split('\n') %}
  {% for line in lines %}
    {% if line.strip() %}
    <div class="focus-item">{{ line.strip().lstrip('0123456789. ') }}</div>
    {% endif %}
  {% endfor %}
</div>
{% endif %}

</div><!-- /container -->

<div class="footer">
  <span>Generated by <strong>simcoach</strong> — open-source AI sim racing coach</span>
  <span>{{ generated_at }}</span>
</div>

<!-- ── Charts script ────────────────────────────────────────────────────────── -->
<script>
const DATA = {{ chart_data_json | safe }};
const positions = DATA.positions;
const best = DATA.best;
const ref = DATA.reference;

const commonOpts = {
  responsive: true,
  maintainAspectRatio: false,
  animation: false,
  elements: { point: { radius: 0 }, line: { borderWidth: 1.5 } },
  plugins: { legend: { display: false } },
  scales: {
    x: {
      type: 'linear',
      min: 0, max: 1,
      ticks: { color: '#7a7f9a', maxTicksLimit: 6,
               callback: v => (v * 100).toFixed(0) + '%' },
      grid: { color: '#2e3250' },
    },
    y: {
      ticks: { color: '#7a7f9a', maxTicksLimit: 5 },
      grid: { color: '#2e3250' },
    }
  }
};

function makeDatasets(key, yLabel, yMin, yMax) {
  const ds = [{
    label: 'Best',
    data: positions.map((x, i) => ({ x, y: best[key][i] })),
    borderColor: '#4ade80',
    backgroundColor: 'rgba(74,222,128,0.06)',
    fill: true,
  }];
  if (ref) {
    ds.push({
      label: 'Reference',
      data: positions.map((x, i) => ({ x, y: ref[key][i] })),
      borderColor: '#60a5fa',
      backgroundColor: 'transparent',
      borderDash: [4, 3],
    });
  }
  return ds;
}

function makeChart(id, key, extra = {}) {
  const ctx = document.getElementById(id);
  if (!ctx) return;
  new Chart(ctx, {
    type: 'line',
    data: { datasets: makeDatasets(key) },
    options: { ...commonOpts, ...extra }
  });
}

makeChart('chartSpeed',    'speed');
makeChart('chartThrottle', 'throttle', { scales: { ...commonOpts.scales, y: { ...commonOpts.scales.y, min: 0, max: 1 } } });
makeChart('chartBrake',    'brake',    { scales: { ...commonOpts.scales, y: { ...commonOpts.scales.y, min: 0, max: 1 } } });
makeChart('chartSteering', 'steering', { scales: { ...commonOpts.scales, y: { ...commonOpts.scales.y, min: -1, max: 1 } } });
</script>
</body>
</html>
