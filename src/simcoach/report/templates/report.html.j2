<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>simcoach — {{ report.track_id }} / {{ report.car_id }}</title>
  <script src="https://cdn.plot.ly/plotly-basic-2.35.2.min.js"></script>
  <style>
    :root {
      --bg: #0f1117;
      --surface: #1a1d27;
      --surface2: #22263a;
      --accent: #e63946;
      --accent2: #457b9d;
      --text: #e8eaf0;
      --muted: #7a7f9a;
      --border: #2e3250;
      --best: #4ade80;
      --ref: #60a5fa;
      --radius: 8px;
      --font: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      font-size: 15px;
      line-height: 1.6;
      padding: 0 0 60px;
    }

    /* ── Header ─────────────────────────────────────────────────────────── */
    .header {
      background: linear-gradient(135deg, #1a1d27 0%, #0f1117 100%);
      border-bottom: 2px solid var(--accent);
      padding: 28px 40px 20px;
    }
    .header h1 {
      font-size: 1.6rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      color: var(--text);
    }
    .header h1 span { color: var(--accent); }
    .header .meta {
      margin-top: 8px;
      color: var(--muted);
      font-size: 0.88rem;
      display: flex;
      gap: 24px;
      flex-wrap: wrap;
    }
    .header .meta strong { color: var(--text); }

    /* ── Layout ─────────────────────────────────────────────────────────── */
    .container { max-width: 1100px; margin: 0 auto; padding: 0 40px; }

    .section {
      margin-top: 36px;
    }
    .section-title {
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
      padding-bottom: 8px;
      margin-bottom: 16px;
    }

    /* ── Cards ───────────────────────────────────────────────────────────── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px 24px;
    }

    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
    @media (max-width: 700px) {
      .grid-2, .grid-3 { grid-template-columns: 1fr; }
    }

    /* ── Lap time display ───────────────────────────────────────────────── */
    .laptime-block {
      display: flex;
      align-items: center;
      gap: 32px;
      padding: 16px 24px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
    }
    .laptime-item { text-align: center; }
    .laptime-item .label { font-size: 0.78rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; }
    .laptime-item .value { font-size: 2rem; font-weight: 700; font-variant-numeric: tabular-nums; }
    .laptime-item.best   .value { color: var(--best); }
    .laptime-item.ref    .value { color: var(--ref); }
    .laptime-item.delta  .value { color: #f59e0b; }
    .divider { width: 1px; height: 60px; background: var(--border); }

    /* ── Stats table ────────────────────────────────────────────────────── */
    .stats-table { width: 100%; border-collapse: collapse; }
    .stats-table th {
      text-align: left;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--muted);
      padding: 6px 12px;
      border-bottom: 1px solid var(--border);
    }
    .stats-table td { padding: 8px 12px; border-bottom: 1px solid var(--border); }
    .stats-table tr:last-child td { border-bottom: none; }
    .stats-table .val-best { color: var(--best); font-weight: 600; }
    .stats-table .val-ref  { color: var(--ref);  font-weight: 600; }

    /* ── Lap history table ──────────────────────────────────────────────── */
    .lap-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    .lap-table th {
      background: var(--surface2);
      text-align: left;
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      color: var(--muted);
      padding: 8px 14px;
    }
    .lap-table td { padding: 8px 14px; border-bottom: 1px solid var(--border); }
    .lap-table tr.is-best td { background: rgba(74,222,128,0.06); color: var(--best); }
    .lap-table .badge {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 1px 6px;
      border-radius: 4px;
      background: var(--accent);
      color: #fff;
      margin-left: 6px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    /* ── Charts ─────────────────────────────────────────────────────────── */
    .chart-container {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px 20px 8px;
    }
    .chart-toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 8px;
      flex-wrap: wrap;
      gap: 8px;
    }
    .chart-toolbar .hint {
      font-size: 0.75rem;
      color: var(--muted);
    }
    .btn-reset-zoom {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 4px;
      color: var(--text);
      font-size: 0.78rem;
      padding: 4px 12px;
      cursor: pointer;
      transition: background 0.15s;
    }
    .btn-reset-zoom:hover { background: var(--border); }
    .plotly-chart { width: 100%; }

    /* ── AI text sections (legacy fallback) ─────────────────────────────── */
    .ai-text {
      line-height: 1.75;
      color: var(--text);
    }

    /* ── Structured AI sections ─────────────────────────────────────────── */
    .ai-summary {
      font-size: 1rem;
      color: var(--text);
      line-height: 1.65;
      margin-bottom: 16px;
      padding-bottom: 14px;
      border-bottom: 1px solid var(--border);
    }
    .ai-list {
      list-style: none;
      padding: 0;
      margin: 0 0 12px;
    }
    .ai-list li {
      padding: 7px 0 7px 18px;
      position: relative;
      color: var(--text);
      font-size: 0.92rem;
      line-height: 1.55;
      border-bottom: 1px solid var(--border);
    }
    .ai-list li:last-child { border-bottom: none; }
    .ai-list li::before {
      content: '›';
      position: absolute;
      left: 0;
      color: var(--accent2);
      font-weight: 700;
    }
    .ai-list.outliers li::before { content: '!'; color: #f59e0b; }
    .ai-subsection-label {
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted);
      margin: 14px 0 6px;
    }
    .ai-subsection-label:first-child { margin-top: 0; }
    .tag-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 4px;
    }
    .tag {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 3px 12px;
      font-size: 0.8rem;
      color: var(--accent2);
    }
    .takeaway-list {
      list-style: none;
      padding: 0;
      margin: 0;
      counter-reset: takeaway;
    }
    .takeaway-list li {
      counter-increment: takeaway;
      display: flex;
      align-items: baseline;
      gap: 12px;
      padding: 9px 0;
      border-bottom: 1px solid var(--border);
      font-size: 0.95rem;
    }
    .takeaway-list li:last-child { border-bottom: none; }
    .takeaway-list li::before {
      content: counter(takeaway);
      min-width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--accent);
      color: #fff;
      font-size: 0.72rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    /* ── Focus items ────────────────────────────────────────────────────── */
    .focus-item {
      background: var(--surface2);
      border-left: 3px solid var(--accent);
      border-radius: 0 var(--radius) var(--radius) 0;
      padding: 14px 18px;
      margin-bottom: 12px;
    }
    .focus-item:last-child { margin-bottom: 0; }
    .focus-item .focus-title {
      font-size: 0.85rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--accent);
      margin-bottom: 5px;
    }
    .focus-item .focus-action {
      font-size: 0.93rem;
      color: var(--text);
      line-height: 1.5;
    }

    /* ── Footer ─────────────────────────────────────────────────────────── */
    .footer {
      margin-top: 48px;
      padding: 16px 40px;
      border-top: 1px solid var(--border);
      color: var(--muted);
      font-size: 0.82rem;
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px;
    }

    /* ── Legend ─────────────────────────────────────────────────────────── */
    .legend {
      display: flex;
      gap: 20px;
      margin-bottom: 12px;
      font-size: 0.82rem;
    }
    .legend-dot {
      width: 12px; height: 12px;
      border-radius: 50%;
      display: inline-block;
      margin-right: 5px;
      vertical-align: middle;
    }
  </style>
</head>
<body>

<!-- ── Header ─────────────────────────────────────────────────────────────── -->
<div class="header">
  <div class="container">
    <h1><span>simcoach</span> — Post-Session Analysis</h1>
    <div class="meta">
      <span>Track: <strong>{{ report.track_id }}</strong></span>
      <span>Car: <strong>{{ report.car_id }}</strong></span>
      <span>Session: <strong>{{ report.session_id }}</strong></span>
      <span>Date: <strong>{{ report.session_date[:10] }}</strong></span>
      <span>Model: <strong>{{ report.llm_model }}</strong></span>
    </div>
  </div>
</div>

<div class="container">

<!-- ── Session Overview ────────────────────────────────────────────────────── -->
<div class="section">
  <div class="section-title">Session Overview</div>
  <div class="laptime-block">
    <div class="laptime-item best">
      <div class="label">Best Lap</div>
      <div class="value">{{ report.best_lap_time_str }}</div>
    </div>
    {% if report.reference_lap_time_str %}
    <div class="divider"></div>
    <div class="laptime-item ref">
      <div class="label">Reference (PB)</div>
      <div class="value">{{ report.reference_lap_time_str }}</div>
    </div>
    <div class="divider"></div>
    <div class="laptime-item delta">
      <div class="label">Delta</div>
      <div class="value">{{ report.delta_vs_reference_str }}</div>
    </div>
    {% endif %}
  </div>
</div>

<!-- ── Lap History ─────────────────────────────────────────────────────────── -->
{% if lap_summaries %}
<div class="section">
  <div class="section-title">Lap History</div>
  <div class="card" style="padding: 0; overflow: hidden;">
    <table class="lap-table">
      <thead>
        <tr>
          <th>Lap</th>
          <th>Time</th>
          <th>Max Speed</th>
          <th>Avg Speed</th>
          <th>Gear Changes</th>
          <th>ABS Events</th>
          <th>TC Events</th>
        </tr>
      </thead>
      <tbody>
        {% for lap in lap_summaries %}
        <tr class="{{ 'is-best' if lap.is_best else '' }}">
          <td>
            {{ lap.lap_id + 1 }}
            {% if lap.is_best %}<span class="badge">Best</span>{% endif %}
          </td>
          <td>{{ lap.lap_time_str }}</td>
          <td>{{ '%.0f km/h' % lap.max_speed_kmh if lap.max_speed_kmh else '—' }}</td>
          <td>{{ '%.0f km/h' % lap.avg_speed_kmh if lap.avg_speed_kmh else '—' }}</td>
          <td>{{ lap.gear_changes if lap.gear_changes is not none else '—' }}</td>
          <td>{{ lap.abs_events if lap.abs_events is not none else '—' }}</td>
          <td>{{ lap.tc_events if lap.tc_events is not none else '—' }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>
{% endif %}

<!-- ── Telemetry Charts ────────────────────────────────────────────────────── -->
<div class="section">
  <div class="section-title">Telemetry Traces — Best Lap vs Reference</div>
  <div class="chart-container">
    <div class="chart-toolbar">
      <div class="legend">
        <span><span class="legend-dot" style="background:#4ade80"></span>Best Lap</span>
        <span><span class="legend-dot" style="background:#60a5fa"></span>Reference</span>
      </div>
      <div style="display:flex;align-items:center;gap:10px;">
        <span class="hint">Scroll to zoom · Drag to pan · Double-click to reset</span>
        <button class="btn-reset-zoom" id="btnResetZoom">Reset Zoom</button>
      </div>
    </div>
    <div id="chartSpeed"    class="plotly-chart"></div>
    <div id="chartThrottle" class="plotly-chart"></div>
    <div id="chartBrake"    class="plotly-chart"></div>
    <div id="chartSteering" class="plotly-chart"></div>
  </div>
</div>

{% if structured and structured.best_lap_vs_reference %}
  {% set bvr = structured.best_lap_vs_reference %}
  {% set sf  = structured.session_findings %}
  {% set cs  = structured.coaching_summary %}
  {% set ntf = structured.next_training_focus %}

<!-- ── Best vs Reference Analysis ─────────────────────────────────────────── -->
<div class="section">
  <div class="section-title">Best Lap vs Reference</div>
  <div class="card">
    {% if bvr.summary %}
    <p class="ai-summary">{{ bvr.summary }}</p>
    {% endif %}
    {% if bvr.time_loss_sections %}
    <div class="ai-subsection-label">Time-loss zones</div>
    <ul class="ai-list">
      {% for item in bvr.time_loss_sections %}
      <li>{{ item }}</li>
      {% endfor %}
    </ul>
    {% endif %}
    {% if bvr.main_causes %}
    <div class="ai-subsection-label">Root causes</div>
    <div class="tag-row">
      {% for cause in bvr.main_causes %}
      <span class="tag">{{ cause }}</span>
      {% endfor %}
    </div>
    {% endif %}
  </div>
</div>

<!-- ── Session Findings ────────────────────────────────────────────────────── -->
<div class="section">
  <div class="section-title">Session Findings</div>
  <div class="card">
    {% if sf.consistency_note %}
    <p class="ai-summary">{{ sf.consistency_note }}</p>
    {% endif %}
    {% if sf.repeated_patterns %}
    <div class="ai-subsection-label">Repeated patterns</div>
    <ul class="ai-list">
      {% for p in sf.repeated_patterns %}
      <li>{{ p }}</li>
      {% endfor %}
    </ul>
    {% endif %}
    {% if sf.outliers %}
    <div class="ai-subsection-label">Outlier laps</div>
    <ul class="ai-list outliers">
      {% for o in sf.outliers %}
      <li>{{ o }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </div>
</div>

<!-- ── Coaching Summary ────────────────────────────────────────────────────── -->
<div class="section">
  <div class="section-title">Coaching Summary</div>
  <div class="card">
    <ol class="takeaway-list">
      {% for t in cs.top_takeaways %}
      <li>{{ t }}</li>
      {% endfor %}
    </ol>
  </div>
</div>

<!-- ── Next Training Focus ─────────────────────────────────────────────────── -->
{% if ntf.priorities %}
<div class="section">
  <div class="section-title">Next Training Focus</div>
  {% for p in ntf.priorities %}
  <div class="focus-item">
    <div class="focus-title">{{ p.title }}</div>
    <div class="focus-action">{{ p.action }}</div>
  </div>
  {% endfor %}
</div>
{% endif %}

{% else %}

<!-- ── Best vs Reference Analysis (legacy) ────────────────────────────────── -->
<div class="section">
  <div class="section-title">Best Lap vs Reference</div>
  <div class="card ai-text">
    {{ report.best_vs_reference_analysis | replace('\n', '<br>') | safe }}
  </div>
</div>

<!-- ── Session Findings (legacy) ──────────────────────────────────────────── -->
<div class="section">
  <div class="section-title">Session Findings</div>
  <div class="card ai-text">
    {{ report.session_findings | replace('\n', '<br>') | safe }}
  </div>
</div>

<!-- ── Coaching Summary (legacy) ──────────────────────────────────────────── -->
<div class="section">
  <div class="section-title">Coaching Summary</div>
  <div class="card ai-text">
    {{ report.coaching_summary | replace('\n', '<br>') | safe }}
  </div>
</div>

<!-- ── Next Training Focus (legacy) ───────────────────────────────────────── -->
{% if report.next_training_focus %}
<div class="section">
  <div class="section-title">Next Training Focus</div>
  {% set lines = report.next_training_focus.split('\n') %}
  {% for line in lines %}
    {% if line.strip() %}
    <div class="focus-item">
      <div class="focus-action">{{ line.strip().lstrip('0123456789. ') }}</div>
    </div>
    {% endif %}
  {% endfor %}
</div>
{% endif %}

{% endif %}

</div><!-- /container -->

<div class="footer">
  <span>Generated by <strong>simcoach</strong> — open-source AI sim racing coach</span>
  <span>{{ generated_at }}</span>
</div>

<!-- ── Telemetry charts (Plotly) ──────────────────────────────────────────── -->
<script>
(function () {
  const DATA = {{ chart_data_json | safe }};
  const pos  = DATA.positions;
  const best = DATA.best;
  const ref  = DATA.reference;

  // ── colour / theme constants ────────────────────────────────────────────
  const C_BEST  = '#4ade80';
  const C_REF   = '#60a5fa';
  const C_PAPER = '#1a1d27';
  const C_PLOT  = '#0f1117';
  const C_GRID  = '#2e3250';
  const C_TEXT  = '#7a7f9a';
  const C_AXIS  = '#e8eaf0';

  // ── channel definitions ─────────────────────────────────────────────────
  // htpl: Plotly hovertemplate format string for the y value only.
  // %.1%  → multiply by 100, 1 decimal, add % sign  (throttle/brake 0-1)
  // %.1f  → 1 decimal float                          (speed)
  // %.3f  → 3 decimal float                          (steering)
  const channels = [
    { id: 'chartSpeed',    key: 'speed',    label: 'Speed (km/h)', yRange: null,          htpl: '%{y:.1f} km/h' },
    { id: 'chartThrottle', key: 'throttle', label: 'Throttle',     yRange: [0, 1.05],     htpl: '%{y:.1%}'      },
    { id: 'chartBrake',    key: 'brake',    label: 'Brake',        yRange: [0, 1.05],     htpl: '%{y:.1%}'      },
    { id: 'chartSteering', key: 'steering', label: 'Steering',     yRange: [-1.05, 1.05], htpl: '%{y:.3f}'      },
  ];

  const isLast = i => i === channels.length - 1;

  // ── build traces: each trace owns ONLY its own value in hovertemplate ───
  // FIX: previously both traces shared the same hovertext (which contained
  //      both Best and Ref data), causing every hover to show duplicate info.
  //      Now each trace uses its own hovertemplate referencing only %{y}.
  //      With hovermode:'x unified', Plotly assembles one tooltip box that
  //      shows the position once and each trace's value on a separate line.
  function makeTraces(key, htpl) {
    const traces = [{
      x: pos,
      y: best[key],
      name: 'Best Lap',
      mode: 'lines',
      line: { color: C_BEST, width: 1.8 },
      hovertemplate: htpl + '<extra>Best</extra>',
    }];
    if (ref) {
      traces.push({
        x: pos,
        y: ref[key],
        name: 'Reference',
        mode: 'lines',
        line: { color: C_REF, width: 1.8, dash: 'dot' },
        hovertemplate: htpl + '<extra>Ref</extra>',
      });
    }
    return traces;
  }

  // ── layout builder ──────────────────────────────────────────────────────
  function makeLayout(label, yRange, showXAxis) {
    return {
      height: 165,
      margin: { t: 6, b: showXAxis ? 36 : 6, l: 68, r: 12 },
      paper_bgcolor: C_PAPER,
      plot_bgcolor:  C_PLOT,
      font: { color: C_TEXT, family: "'Segoe UI', system-ui, sans-serif", size: 11 },
      showlegend: false,
      hovermode: 'x unified',
      xaxis: {
        visible: showXAxis,
        tickformat:  '.0%',
        hoverformat: '.1%',   // formats the shared x label in unified tooltip
        range: [0, 1],
        gridcolor:     C_GRID,
        zerolinecolor: C_GRID,
        color: C_TEXT,
        tickfont: { color: C_TEXT },
        title: showXAxis ? { text: 'Track position', font: { color: C_TEXT, size: 10 } } : undefined,
      },
      yaxis: {
        title: { text: label, font: { color: C_TEXT, size: 10 } },
        range: yRange,
        gridcolor:     C_GRID,
        zerolinecolor: C_GRID,
        color: C_AXIS,
        tickfont: { color: C_TEXT },
        fixedrange: false,
      },
      dragmode: 'zoom',
    };
  }

  const plotConfig = {
    responsive: true,
    scrollZoom:  true,
    displayModeBar: true,
    modeBarButtonsToRemove: ['toImage', 'sendDataToCloud', 'lasso2d', 'select2d'],
    displaylogo: false,
  };

  // ── initial render ──────────────────────────────────────────────────────
  channels.forEach(({ id, key, label, yRange, htpl }, i) => {
    Plotly.newPlot(id, makeTraces(key, htpl), makeLayout(label, yRange, isLast(i)), plotConfig);
  });

  // ── linked x-axis sync (async-safe) ────────────────────────────────────
  //
  // ROOT CAUSE of the original freeze:
  //   Plotly.relayout() is async (returns a Promise). The old code set
  //   `syncing = false` immediately after launching the three relayout calls,
  //   before those Promises resolved. The deferred `plotly_relayout` events
  //   that fired later all saw syncing=false and each tried to sync the
  //   remaining charts, producing an exponentially growing event storm.
  //
  // FIX:
  //   Make the event handler async. Use Promise.all to await every relayout
  //   call before releasing the lock. try/finally ensures the lock is always
  //   released even if a relayout throws. Only x-axis fields are synced;
  //   all other relayout payloads (y-axis, legend, etc.) are ignored.
  //
  let isSyncing = false;

  channels.forEach(({ id }) => {
    document.getElementById(id).on('plotly_relayout', async function (ed) {
      if (isSyncing) return;

      let update = null;
      if ('xaxis.range[0]' in ed) {
        update = { 'xaxis.range[0]': ed['xaxis.range[0]'], 'xaxis.range[1]': ed['xaxis.range[1]'] };
      } else if (ed['xaxis.autorange'] === true) {
        update = { 'xaxis.autorange': true };
      }
      if (!update) return;  // ignore non-x relayout events (y zoom, etc.)

      isSyncing = true;
      try {
        await Promise.all(
          channels.filter(c => c.id !== id).map(c => Plotly.relayout(c.id, update))
        );
      } finally {
        isSyncing = false;
      }
    });
  });

  // ── reset zoom button ────────────────────────────────────────────────────
  document.getElementById('btnResetZoom').addEventListener('click', async () => {
    isSyncing = true;
    try {
      await Promise.all(
        channels.map(({ id }) =>
          Plotly.relayout(id, { 'xaxis.autorange': true, 'yaxis.autorange': true })
        )
      );
    } finally {
      isSyncing = false;
    }
  });

})();
</script>
</body>
</html>
